# Copy this file to ".env" for LOCAL testing only (vercel dev).
# .env is gitignored and must NEVER be committed.
# In production these live in Vercel -> Settings -> Environments -> Production.

EBAY_ACCOUNT_SID=your_account_sid_here
EBAY_AUTH_TOKEN=your_auth_token_here

# Secret gate for /api/ebay. Generate with: openssl rand -hex 32
# Callers must send it as header "x-proxy-key" or query "?key=".
EBAY_PROXY_KEY=your_random_proxy_key_here
